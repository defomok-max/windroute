# ────────────────────────────────────────────────
# windbu — конфигурация (Windows)
# Пустые значения = автогенерация при первом запуске
# ────────────────────────────────────────────────

# HTTP-сервер
PORT=20129
HOST=127.0.0.1

# API-ключ для клиентов (Claude Code / Cursor / Cline).
# Если пусто — install.ps1 сгенерит sk-windbu-<рандом> при установке.
API_KEY=

# Пароль в Dashboard (http://127.0.0.1:20129/dashboard).
# Если пусто — install.ps1 сгенерит случайный при установке.
DASHBOARD_PASSWORD=

# Путь к Windsurf Language Server.
# install.ps1 / detect-ls.ps1 пытаются найти его автоматически.
# Обычные места: %LOCALAPPDATA%\Programs\Windsurf\resources\app\extensions\windsurf\bin\
# или %APPDATA%\Windsurf\bin\
LS_BINARY_PATH=

# gRPC-порт Language Server (внутренний, не меняй без нужды)
LS_PORT=42100

# Корневая папка данных (аккаунты, статистика, логи, рабочая область LS).
# По умолчанию %USERPROFILE%\.windbu
# WINDBU_DATA_DIR=

# Модель по умолчанию, если клиент не передал `model`
DEFAULT_MODEL=claude-sonnet-4.6

# Максимум токенов в ответе по умолчанию
MAX_TOKENS=8192

# Уровень логов: debug | info | warn | error
LOG_LEVEL=info

# Windsurf Cloud — не меняй
CODEIUM_API_URL=https://server.self-serve.windsurf.com
